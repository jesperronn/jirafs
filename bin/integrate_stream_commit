#!/usr/bin/env bash

set -euo pipefail

MAX_ATTEMPTS=5
MIN_BACKOFF=1
MAX_BACKOFF=3

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${REPO_ROOT}"

target="${1:-main}"

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "integrate: worktree must be clean before integration" >&2
  exit 1
fi

attempt=1
while [ "${attempt}" -le "${MAX_ATTEMPTS}" ]; do
  echo "integrate: attempt ${attempt}/${MAX_ATTEMPTS} for HEAD -> ${target}"

  git rebase "${target}"

  head_commit="$(git rev-parse HEAD)"
  target_commit="$(git rev-parse "${target}")"

  if [ "${head_commit}" = "${target_commit}" ]; then
    echo "integrate: HEAD is already in ${target} — nothing to push" >&2
    exit 0
  fi

  # Check if head_commit is reachable from target (already merged)
  if git merge-base --is-ancestor "${head_commit}" "${target}"; then
    echo "integrate: HEAD is already in ${target} — nothing to push" >&2
    exit 0
  fi

  bin/test
  bin/lint

  if git push . "${head_commit}:${target}"; then
    echo "integrate: pushed ${head_commit} to ${target}"
    exit 0
  fi

  if [ "${attempt}" -eq "${MAX_ATTEMPTS}" ]; then
    echo "integrate: push failed after ${MAX_ATTEMPTS} attempts" >&2
    exit 1
  fi

  backoff="$(awk -v min="${MIN_BACKOFF}" -v max="${MAX_BACKOFF}" 'BEGIN { srand(); printf "%.3f", min + rand() * (max - min) }')"
  echo "integrate: push failed; retrying full gate after ${backoff}s" >&2
  sleep "${backoff}"
  attempt=$((attempt + 1))
done
