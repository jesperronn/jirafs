#!/usr/bin/env bash

set -euo pipefail

MAX_ATTEMPTS=5
MIN_BACKOFF=1
MAX_BACKOFF=3

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# Skip cd when INTEGRATE_RETRY_TEST=1 to avoid changing to the actual
# repo root (which may have uncommitted changes) during retry tests.
if [ "${INTEGRATE_RETRY_TEST:-}" != "1" ]; then
  cd "${REPO_ROOT}"
fi

target="${1:-main}"

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "integrate: worktree must be clean before integration" >&2
  exit 1
fi

attempt=1
while true; do
  echo "integrate: attempt ${attempt}/${MAX_ATTEMPTS} for HEAD -> ${target}"

  # Rebase onto target; stop before push on failure.
  if ! git rebase "${target}"; then
    echo "integrate: rebase failed — stopping before push" >&2
    exit 1
  fi

  head_commit="$(git rev-parse HEAD)"
  target_commit="$(git rev-parse "${target}")"

  if [ "${head_commit}" = "${target_commit}" ]; then
    echo "integrate: HEAD is already in ${target} — nothing to push" >&2
    exit 0
  fi

  # Check if head_commit is reachable from target (already merged)
  if git merge-base --is-ancestor "${head_commit}" "${target}"; then
    echo "integrate: HEAD is already in ${target} — nothing to push" >&2
    exit 0
  fi

  # Gate: test and lint must pass before push.
  # Skip when INTEGRATE_RETRY_TEST=1 to avoid recursive bin/test loops
  # in the retry test's own setup.
  if [ "${INTEGRATE_RETRY_TEST:-}" != "1" ]; then
    if ! bin/test; then
      echo "integrate: test failed — stopping before push" >&2
      exit 1
    fi
    if ! bin/lint; then
      echo "integrate: lint failed — stopping before push" >&2
      exit 1
    fi
  fi

  if git push . "${head_commit}:${target}"; then
    echo "integrate: pushed ${head_commit} to ${target}"
    exit 0
  fi

  echo "integrate: push failed after ${attempt}/${MAX_ATTEMPTS} attempt" >&2
  if [ "${attempt}" -ge "${MAX_ATTEMPTS}" ]; then
    echo "integrate: push failed after ${MAX_ATTEMPTS} attempts" >&2
    exit 1
  fi

  backoff="$(awk -v min="${MIN_BACKOFF}" -v max="${MAX_BACKOFF}" 'BEGIN { srand(); printf "%.3f", min + rand() * (max - min) }')"
  echo "integrate: push failed; retrying full gate after ${backoff}s" >&2
  sleep "${backoff}"
  attempt=$((attempt + 1))
done
